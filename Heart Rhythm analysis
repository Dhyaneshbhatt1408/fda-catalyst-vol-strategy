    {
      "cell_type": "code",
      "source": [
        "def bandpass_filter_ecg(raw_signal, fs, lowcut=0.5, highcut=40.0, order=4):\n",
        "    \"\"\"\n",
        "    Applies a Butterworth bandpass filter to remove baseline wander (low freq)\n",
        "    and muscle/powerline noise (high freq), isolating the cardiac signal band.\n",
        "    \"\"\"\n",
        "    nyquist = 0.5 * fs\n",
        "    low = lowcut / nyquist\n",
        "    high = highcut / nyquist\n",
        "    b, a = sig.butter(order, [low, high], btype=\"band\")\n",
        "    filtered = sig.filtfilt(b, a, raw_signal)\n",
        "    return filtered\n",
        "\n",
        "\n",
        "# Apply filtering to every downloaded record, using the first ECG channel (MLII lead)\n",
        "filtered_signals = {}\n",
        "for rec_name, data in raw_records.items():\n",
        "    record = data[\"record\"]\n",
        "    fs = record.fs\n",
        "    raw_signal = record.p_signal[:, 0]  # first lead, typically MLII\n",
        "    filtered = bandpass_filter_ecg(raw_signal, fs)\n",
        "    filtered_signals[rec_name] = {\"signal\": filtered, \"fs\": fs}\n",
        "    print(f\"  ✓ Filtered record {rec_name} (sampling rate: {fs} Hz)\")\n",
        "\n",
        "print(f\"\\nFiltered {len(filtered_signals)} ECG signals.\")"
      ],
