      "source": [
        "# A subset of MIT-BIH records with a good mix of normal and abnormal beats.\n",
        "# Full database has 48 records; using a subset keeps runtime reasonable.\n",
        "RECORD_NAMES = [\"100\", \"101\", \"103\", \"106\", \"108\", \"109\", \"111\", \"112\", \"113\", \"114\"]\n",
        "PHYSIONET_DB = \"mitdb\"\n",
        "\n",
        "def download_ecg_record(record_name, db_name=PHYSIONET_DB):\n",
        "    \"\"\"\n",
        "    Downloads a single ECG record and its beat annotations from PhysioNet.\n",
        "    Returns None gracefully if the record can't be fetched.\n",
        "    \"\"\"\n",
        "    try:\n",
        "        record = wfdb.rdrecord(record_name, pn_dir=db_name)\n",
        "        annotation = wfdb.rdann(record_name, \"atr\", pn_dir=db_name)\n",
        "        return record, annotation\n",
        "    except Exception as e:\n",
        "        print(f\"  [skip] Record {record_name}: {e}\")\n",
        "        return None, None\n",
        "\n",
        "\n",
        "print(\"Downloading ECG records from PhysioNet MIT-BIH Arrhythmia Database...\\n\")\n",
        "raw_records = {}\n",
        "for rec_name in RECORD_NAMES:\n",
        "    record, annotation = download_ecg_record(rec_name)\n",
        "    if record is not None:\n",
        "        raw_records[rec_name] = {\"record\": record, \"annotation\": annotation}\n",
        "        print(f\"  ✓ Record {rec_name}: {record.sig_len} samples, \"\n",
        "              f\"{len(annotation.sample)} annotated beats\")\n",
        "\n",
        "if not raw_records:\n",
        "    raise RuntimeError(\"No ECG records could be downloaded — check network access to physionet.org.\")\n",
        "\n",
        "print(f\"\\nSuccessfully downloaded {len(raw_records)}/{len(RECORD_NAMES)} records.\")"
