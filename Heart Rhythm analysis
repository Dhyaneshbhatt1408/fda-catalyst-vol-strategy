    },
    {
      "cell_type": "code",
      "source": [
        "# MIT-BIH annotation symbols mapped to clinically meaningful categories.\n",
        "# Reference: https://archive.physionet.org/physiobank/annotations.shtml\n",
        "BEAT_LABEL_MAP = {\n",
        "    \"N\": \"Normal\",\n",
        "    \"L\": \"Normal\",       # Left bundle branch block beat (grouped as normal-ish for this demo)\n",
        "    \"R\": \"Normal\",       # Right bundle branch block beat\n",
        "    \"V\": \"PVC\",          # Premature ventricular contraction — clinically significant\n",
        "    \"A\": \"APB\",          # Atrial premature beat\n",
        "    \"F\": \"Fusion\",       # Fusion of ventricular and normal beat\n",
        "}\n",
        "\n",
        "def segment_beats(filtered_signal, annotation, fs, window_sec=0.6):\n",
        "    \"\"\"\n",
        "    Extracts a fixed-length window around each annotated R-peak.\n",
        "    Returns a list of (beat_segment, label) tuples, skipping unrecognized\n",
        "    annotation types and beats too close to the signal edges.\n",
        "    \"\"\"\n",
        "    half_window = int((window_sec / 2) * fs)\n",
        "    beats, labels = [], []\n",
        "\n",
        "    for sample_idx, symbol in zip(annotation.sample, annotation.symbol):\n",
        "        if symbol not in BEAT_LABEL_MAP:\n",
        "            continue\n",
        "        start = sample_idx - half_window\n",
        "        end = sample_idx + half_window\n",
        "        if start < 0 or end > len(filtered_signal):\n",
        "            continue\n",
        "        beats.append(filtered_signal[start:end])\n",
        "        labels.append(BEAT_LABEL_MAP[symbol])\n",
        "\n",
        "    return beats, labels\n",
        "\n",
        "\n",
        "all_beats, all_labels, all_record_sources = [], [], []\n",
        "for rec_name, sig_data in filtered_signals.items():\n",
        "    annotation = raw_records[rec_name][\"annotation\"]\n",
        "    beats, labels = segment_beats(sig_data[\"signal\"], annotation, sig_data[\"fs\"])\n",
        "    all_beats.extend(beats)\n",
        "    all_labels.extend(labels)\n",
        "    all_record_sources.extend([rec_name] * len(beats))\n",
        "    print(f\"  ✓ Record {rec_name}: segmented {len(beats)} beats\")\n",
        "\n",
        "print(f\"\\nTotal segmented heartbeats across all records: {len(all_beats)}\")\n",
        "\n",
        "label_counts = pd.Series(all_labels).value_counts()\n",
        "print(\"\\nBeat type distribution:\")\n",
        "print(tabulate(label_counts.reset_index().values, headers=[\"Beat Type\", \"Count\"], tablefmt=\"github\"))"
