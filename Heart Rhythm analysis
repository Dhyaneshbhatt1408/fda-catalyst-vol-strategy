    {
      "cell_type": "code",
      "source": [
        "def extract_beat_features(beat_segment):\n",
        "    \"\"\"\n",
        "    Computes a feature vector describing the shape and statistics of a single\n",
        "    heartbeat waveform segment.\n",
        "    \"\"\"\n",
        "    features = {\n",
        "        \"mean_amplitude\": np.mean(beat_segment),\n",
        "        \"std_amplitude\": np.std(beat_segment),\n",
        "        \"max_amplitude\": np.max(beat_segment),\n",
        "        \"min_amplitude\": np.min(beat_segment),\n",
        "        \"peak_to_peak\": np.max(beat_segment) - np.min(beat_segment),\n",
        "        \"skewness\": skew(beat_segment),\n",
        "        \"kurtosis\": kurtosis(beat_segment),\n",
        "        \"signal_energy\": np.sum(beat_segment ** 2),\n",
        "    }\n",
        "    return features\n",
        "\n",
        "\n",
        "def compute_rr_intervals(annotation, fs, valid_symbols):\n",
        "    \"\"\"\n",
        "    Computes the time (in seconds) since the previous valid beat for each beat —\n",
        "    RR interval is a key clinical indicator of arrhythmia since abnormal beats\n",
        "    often arrive earlier or later than expected.\n",
        "    \"\"\"\n",
        "    rr_intervals = [np.nan]  # first beat has no previous beat\n",
        "    valid_samples = [s for s, sym in zip(annotation.sample, annotation.symbol) if sym in valid_symbols]\n",
        "    for i in range(1, len(valid_samples)):\n",
        "        rr_intervals.append((valid_samples[i] - valid_samples[i - 1]) / fs)\n",
        "    return rr_intervals\n",
        "\n",
        "\n",
        "feature_rows = []\n",
        "beat_idx = 0\n",
        "for rec_name, sig_data in filtered_signals.items():\n",
        "    annotation = raw_records[rec_name][\"annotation\"]\n",
        "    fs = sig_data[\"fs\"]\n",
        "    rr_intervals = compute_rr_intervals(annotation, fs, BEAT_LABEL_MAP.keys())\n",
        "\n",
        "    rr_pointer = 0\n",
        "    for sample_idx, symbol in zip(annotation.sample, annotation.symbol):\n",
        "        if symbol not in BEAT_LABEL_MAP:\n",
        "            continue\n",
        "        if beat_idx >= len(all_beats) or all_record_sources[beat_idx] != rec_name:\n",
        "            rr_pointer += 1\n",
        "            continue\n",
        "        feats = extract_beat_features(all_beats[beat_idx])\n",
        "        feats[\"rr_interval_sec\"] = rr_intervals[rr_pointer] if rr_pointer < len(rr_intervals) else np.nan\n",
        "        feats[\"label\"] = all_labels[beat_idx]\n",
        "        feats[\"source_record\"] = rec_name\n",
        "        feature_rows.append(feats)\n",
        "        beat_idx += 1\n",
        "        rr_pointer += 1\n",
        "\n",
        "features_df = pd.DataFrame(feature_rows)\n",
        "features_df[\"rr_interval_sec\"] = features_df[\"rr_interval_sec\"].fillna(features_df[\"rr_interval_sec\"].median())\n",
        "\n",
        "print(f\"Extracted features for {len(features_df)} heartbeats.\")\n",
        "features_df.head()"
      ],
